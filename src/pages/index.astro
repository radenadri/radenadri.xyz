---
import "../styles/global.css";

import SidebarLayout from "../layouts/SidebarLayout.astro";

const posts = await Astro.glob("./posts/*.md");
const projects = await Astro.glob("./projects/*.md");
---

<SidebarLayout title="Adrian - Fullstack Developer 🖥️">
  <section class="about">
    <h2><span class="icon">👤</span> About me</h2>
    <p>
      Enthusiastic developer with a passion for creating engaging digital
      experiences. Currently working as a full stack developer with my daily
      tools such as Laravel, Vue, TypeScript, and also Flutter.
    </p>
  </section>

  <section class="posts">
    <h2><span class="icon">📡</span> Posts</h2>
    {
      posts.map((post) => (
        <div class="post-item">
          <a href={post.url} class="post-title">
            {post.frontmatter.title}
          </a>
          <p class="post-description">{post.frontmatter.description}</p>
        </div>
      ))
    }
  </section>

  <section class="projects">
    <h2><span class="icon">📁</span> Projects</h2>
    {
      projects.map((project) => (
        <div class="project-item">
          <a href={project.frontmatter.url} class="project-title">
            {project.frontmatter.title}
          </a>
          <p class="project-description">{project.frontmatter.description}</p>
        </div>
      ))
    }
  </section>
</SidebarLayout>

<style>
  section {
    margin: 2rem 0;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 8px;
  }

  .post-item,
  .project-item,
  .experience-item {
    margin: 1.5rem 0;
  }

  .post-title,
  .project-title {
    font-size: 1.2rem;
    color: #fff;
    text-decoration: none;
    display: block;
    margin-bottom: 0.5rem;
  }

  .post-date,
  .project-date {
    font-size: 0.8rem;
    color: #666;
  }

  .experience-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .date {
    color: #666;
    font-size: 0.9rem;
  }

  h2 {
    font-size: 1.5rem;
    margin: 0rem 0 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .icon {
    font-size: 1.2rem;
  }
</style>
